FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy frontend source
COPY frontend/ .

# Expose Vite's default port
EXPOSE 5173

# Start Vite in dev mode with host binder for Docker
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
