# ─── Database ───────────────────────────────────────────────────────────────
# For Docker: postgresql+asyncpg://citysync:citysync_secret@postgres:5432/citysync
# For Local:  postgresql+asyncpg://citysync:citysync_secret@localhost:5432/citysync
DATABASE_URL=postgresql+asyncpg://citysync:citysync_secret@localhost:5432/citysync
DATABASE_URL_SYNC=postgresql://citysync:citysync_secret@localhost:5432/citysync

# ─── Redis ───────────────────────────────────────────────────────────────────
# For Docker: redis://redis:6379/0
# For Local:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── MinIO (S3) ──────────────────────────────────────────────────────────────
# For Docker: minio:9000
# For Local:  localhost:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=citysync_minio
MINIO_SECRET_KEY=citysync_minio_secret
MINIO_BUCKET=citysync
MINIO_SECURE=false

# ─── OpenAI (set MOCK_AI=true to skip) ───────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
MOCK_AI=true

# ─── Mapbox (set MOCK_MAP=true to use OSM tiles) ─────────────────────────────
MAPBOX_TOKEN=your_mapbox_token_here
MOCK_MAP=true

# ─── Twilio (set MOCK_NOTIFICATIONS=true to skip) ─────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890
MOCK_NOTIFICATIONS=true

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=alerts@citysync.in
MOCK_EMAIL=true

# ─── Privacy / Security ───────────────────────────────────────────────────────
HMAC_SECRET_KEY=generate-a-long-random-string-here
JWT_SECRET_KEY=generate-another-long-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Webhook ──────────────────────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=generate-a-webhook-signing-secret-here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Services ─────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
ROUTING_PORT=8001
VERIFICATION_PORT=8002
DEPT_PORTAL_PORT=3000
