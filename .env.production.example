# CitySync Production Environment Configuration
# Copy this to .env (or set these in Render Environment Variables)

# ── App Environment ───────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=*

# ── Secrets (CHANGE THESE!) ───────────────────────────────────────────────────
# Generate long, random strings for these.
HMAC_SECRET_KEY=replace-with-a-64-character-random-string
JWT_SECRET_KEY=replace-with-a-64-character-random-string
WEBHOOK_HMAC_SECRET=replace-with-a-64-character-random-string

# ── Database ─────────────────────────────────────────────────────────────────
# Example for Supabase: postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=
DATABASE_URL_SYNC=

# ── Redis ────────────────────────────────────────────────────────────────────
# Example for Upstash: rediss://default:[YOUR-PASSWORD]@region.upstash.io:6379
REDIS_URL=

# ── AI Pipeline (Groq / OpenAI) ──────────────────────────────────────────────
# We recommend Groq for high-speed analysis
GROQ_API_KEY=
OPENAI_API_KEY=
# Set to False to use real AI
MOCK_AI=False

# ── Mapbox (For Frontend) ─────────────────────────────────────────────────────
# VITE_MAPBOX_TOKEN must be prefixed with VITE_ for the frontend to pick it up
VITE_MAPBOX_TOKEN=

# ── Features (Disabled for now) ──────────────────────────────────────────────
MOCK_NOTIFICATIONS=True
MOCK_EMAIL=True

# ── MinIO / S3-Compatible Storage ────────────────────────────────────────────
# If using a managed S3-like service (e.g. AWS S3, Cloudflare R2)
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=
# MINIO_SECURE=True
